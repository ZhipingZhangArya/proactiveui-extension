# Clerk authentication
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: override the default Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Database (Vercel Postgres / Neon / Supabase — any Postgres URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Anthropic API key (optional — falls back to mock intent analyzer if missing)
ANTHROPIC_API_KEY=sk-ant-xxx
