# Auth.js (NextAuth) — generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-long-random-string
# In production, also set NEXTAUTH_URL=https://your-app.vercel.app

# Database (Vercel Postgres / Neon / Supabase — any Postgres URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Anthropic API key (optional — falls back to mock intent analyzer if missing)
ANTHROPIC_API_KEY=sk-ant-xxx
